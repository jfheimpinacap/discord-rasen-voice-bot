# Token del bot de Discord. No publiques este valor ni lo subas al repositorio.
DISCORD_TOKEN=

# Identificadores snowflake de Discord; deben conservarse como texto.
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# URL SQLite de desarrollo. La ruta relativa se resuelve desde prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# development | test | production
NODE_ENV=development
